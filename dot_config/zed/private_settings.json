{
  "notification_panel": {
    "show_count_badge": true
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false
  },
  "document_symbols": "on",
  "audio": {
    "experimental.auto_microphone_volume": true,
    "experimental.rodio_audio": true
  },
  "document_folding_ranges": "on",
  "semantic_tokens": "combined",
  "vim": {
    "use_smartcase_find": true,
    "gdefault": true,
    "toggle_relative_line_numbers": true
  },
  "context_servers": {},
  "agent_servers": {
    "opencode": {
      "default_model": "openai/gpt-5.4",
      "favorite_models": [
        "openai/gpt-5.4"
      ],
      "default_mode": "plan",
      "type": "registry"
    }
  },
  "bottom_dock_layout": "contained",
  "status_bar": {
    "active_encoding_button": "non_utf8"
  },
  "which_key": {
    "enabled": true
  },
  "buffer_line_height": "comfortable",
  "ui_font_family": ".ZedSans",
  "ssh_connections": [
    {
      "host": "work",
      "args": [],
      "projects": [],
      "nickname": "Work"
    },
    {
      "host": "mc",
      "args": [],
      "projects": [],
      "nickname": "McServer"
    }
  ],
  "centered_layout": {
    "right_padding": null,
    "left_padding": null
  },
  "completion_menu_scrollbar": "auto",
  "restore_on_startup": "launchpad",
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware"
  },
  "minimap": {
    "show": "auto"
  },
  "colorize_brackets": true,
  "buffer_font_family": "Monaspace Argon",
  "git_panel": {
    "show_count_badge": true,
    "file_icons": true,
    "tree_view": true,
    "status_style": "icon",
    "sort_by_path": true,
    "collapse_untracked_diff": true,
  },
  "project_panel": {
    "diagnostic_badges": true,
    "hide_hidden": false,
    "bold_folder_labels": true,
    "sort_mode": "directories_first",
    "show_diagnostics": "errors",
    "git_status": true,
    "hide_gitignore": false,
    "default_width": 240.0,
    "entry_spacing": "comfortable",
    "hide_root": true,
  },
  "search": {
    "whole_word": true,
    "case_sensitive": true,
    "include_ignored": true,
    "regex": true,
    "center_on_match": true,
  },
  "use_smartcase_search": true,
  "sticky_scroll": {
    "enabled": true,
  },
  "autoscroll_on_clicks": true,
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "relative_line_numbers": "enabled",
  "toolbar": {
    "code_actions": true,
  },
  "always_treat_brackets_as_autoclosed": true,
  "inlay_hints": {
    "show_background": true,
    "enabled": true,
  },
  "edit_predictions": {
    "mode": "eager",
  },
  "agent": {
    "single_file_review": true,
    "show_turn_stats": true,
    "tool_permissions": {
      "default": "allow"
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "use_modifier_to_send": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "play_sound_when_agent_done": true,
    "default_profile": "ask",
    "model_parameters": [],
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "prettier": {
    "allowed": false,
  },
  "close_on_file_delete": true,
  "use_system_window_tabs": true,
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": true,
    "show_branch_icon": true,
  },
  "terminal": {
    "show_count_badge": true,
    "shell": "system",
    "toolbar": {
      "breadcrumbs": true,
    },
    "option_as_meta": true,
    "copy_on_select": true,
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "calls": {
    "mute_on_join": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "helix_mode": true,
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "redact_private_values": true,
  "vim_mode": true,
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
}
