[init]
        defaultBranch = main
[user]
        name = Karl Hans Laurits
        email = karl@laurits.dev
[gpg]
        format = x509
[gpg "x509"]
        program = gitsign
[gitsign]
        connectorID = https://accounts.google.com
        matchCommitter = true
        timestampURL = http://timestamp.digicert.com
[core]
        fsmonitor = true
        untrackedCache = true
        pager = delta
[interactive]
        diffFilter = delta --color-only
[delta]
        navigate = true
        side-by-side = true
        line-numbers = true
[tag]
        sort = version:refname
        gpgsign = true
[commit]
        verbose = true
        gpgsign = true
[push]
        autoSetupRemote = true
        followTags = true
[pull]
        rebase = true
[fetch]
        prune = true
        pruneTags = true
        all = true
[merge]
        conflictstyle = zdiff3
[rebase]
        autoSquash = true
        autoStash = true
        updateRefs = true
[rerere]
        enabled = true
        autoupdate = true
[column]
        ui = auto
[branch]
        sort = -committerdate
[diff]
        algorithm = histogram
        colorMoved = plain
        mnemonicPrefix = true
[help]
        autocorrect = prompt
