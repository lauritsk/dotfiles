[settings]
color_theme = "catppuccin"
experimental = true
activate_aggressive = true
pin = true
lockfile = true
# locked = true
# install_before = "7d"
trusted_config_paths = ["{{ .chezmoi.homeDir }}/Projects"]

[settings.npm]
package_manager = "bun"

[settings.python]
uv_venv_auto = "create|source"

[settings.age]
key_file = "{{ .chezmoi.homeDir }}/.ssh/age.txt"

[env]
MISE_GITHUB_TOKEN = { age = "" }
fish_greeting = ""
fish_key_bindings = "fish_vi_key_bindings"
BAT_THEME_LIGHT = "Catppuccin Latte"
BAT_THEME_DARK = "Catppuccin Mocha"
SHELL = "fish"
EDITOR = "hx"
PAGER = "bat"

[shell_alias]
cm = "chezmoi"
lg = "lazygit"
ld = "lazydocker"
y = "yazi"
oc = "opencode"
ts = "tailscale"
dc = "docker compose"
dev = "devcontainer up --dotfiles-repository https://github.com/{{ .userName }}/dotfiles && devcontainer exec --workspace-folder . fish"

[tools]
age = "1.3.1"
atuin = "18.13.3"
bat = "0.26.1"
bun = "1.3.11"
cargo-binstall = "1.17.7"
chezmoi = "2.70.0"
codex = "0.115.0"
devcontainer-cli = "0.84.1"
fd = "10.4.2"
fnox = "1.18.0"
fzf = "0.70.0"
gh = "2.88.1"
go = "1.26.1"
helix = "25.07.1"
lazydocker = "0.25.0"
lazygit = "0.60.0"
node = "25.8.1"
opencode = "1.2.27"
pnpm = "10.32.1"
python = "3.14.3"
rg = "15.1.0"
sqlite = "3.52.0"
starship = "1.24.2"
tmux = "3.6a"
usage = "3.0.0"
uv = "0.10.11"
wrangler = "4.75.0"
yazi = "26.1.22"
zoxide = "0.9.9"
